// TNG Group Wallet — Pool Engine schema
// Subset of the full hackathon spec: only the shared Pool Engine
// (auth, pools, members, invites, contributions, spend-requests, votes,
// transactions, notifications). Family-specific tables (income streams,
// budget plans, scam alerts, grants) are intentionally omitted in this slice.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER & AUTH ====================

model User {
  id            String    @id @default(cuid())
  phone         String    @unique
  email         String?   @unique
  fullName      String
  displayName   String
  avatarUrl     String?
  pinHash       String
  kycStatus     KycStatus @default(PENDING)
  preferredLang Language  @default(MS)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  mainBalance Decimal @default(0) @db.Decimal(12, 2)

  poolMemberships PoolMember[]
  contributions   Contribution[]
  spendRequests   SpendRequest[]
  votes           Vote[]
  notifications   Notification[]
  transactions    Transaction[]
  sentInvites     PoolInvite[]   @relation("InviteSender")
  receivedInvites PoolInvite[]   @relation("InviteReceiver")
  refreshTokens   RefreshToken[]
  poolsCreated    Pool[]         @relation("PoolCreator")
}

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum Language {
  EN
  MS
  ZH
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==================== POOL ENGINE ====================

model Pool {
  id             String     @id @default(cuid())
  type           PoolType
  name           String
  description    String?
  coverImageUrl  String?
  currency       String     @default("MYR")
  targetAmount   Decimal?   @db.Decimal(12, 2)
  currentBalance Decimal    @default(0) @db.Decimal(12, 2)
  status         PoolStatus @default(ACTIVE)

  approvalMode      ApprovalMode @default(MAJORITY)
  approvalThreshold Int          @default(51)
  spendLimit        Decimal?     @db.Decimal(12, 2)
  emergencyOverride Boolean      @default(false)

  startDate   DateTime  @default(now())
  endDate     DateTime?
  isArchived  Boolean   @default(false)
  isFrozen    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String

  createdBy     User           @relation("PoolCreator", fields: [createdById], references: [id])
  members       PoolMember[]
  contributions Contribution[]
  spendRequests SpendRequest[]
  transactions  Transaction[]
  invites       PoolInvite[]

  @@index([type, status])
  @@index([createdById])
}

enum PoolType {
  TRIP
  FAMILY
}

enum PoolStatus {
  DRAFT
  ACTIVE
  PAUSED
  SETTLED
  ARCHIVED
}

enum ApprovalMode {
  MAJORITY
  UNANIMOUS
  THRESHOLD
  ADMIN_ONLY
}

model PoolMember {
  id                 String     @id @default(cuid())
  poolId             String
  userId             String
  role               MemberRole @default(MEMBER)
  contributionWeight Decimal    @default(1.0) @db.Decimal(5, 2)
  joinedAt           DateTime   @default(now())
  leftAt             DateTime?
  isActive           Boolean    @default(true)

  // ZK eligibility proof (Family Pool only). Real cryptographic proofs
  // arrive in the next slice; for now zkProof holds a placeholder object
  // and zkVerified is set by the verify endpoint.
  zkCommitmentHash   String?
  zkProof            Json?
  zkVerified         Boolean    @default(false)
  zkVerifiedAt       DateTime?

  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([poolId, userId])
  @@index([userId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model PoolInvite {
  id          String       @id @default(cuid())
  poolId      String
  senderId    String
  receiverId  String?
  invitePhone String?
  inviteCode  String       @unique
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  pool     Pool  @relation(fields: [poolId], references: [id], onDelete: Cascade)
  sender   User  @relation("InviteSender", fields: [senderId], references: [id])
  receiver User? @relation("InviteReceiver", fields: [receiverId], references: [id])

  @@index([poolId])
  @@index([status])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// ==================== CONTRIBUTIONS ====================

model Contribution {
  id          String             @id @default(cuid())
  poolId      String
  userId      String
  amount      Decimal            @db.Decimal(12, 2)
  type        ContributionType   @default(MANUAL)
  description String?
  receiptUrl  String?
  status      ContributionStatus @default(COMPLETED)
  createdAt   DateTime           @default(now())

  pool         Pool          @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([poolId])
  @@index([userId])
  @@index([createdAt])
}

enum ContributionType {
  MANUAL
  AUTO_INCOME
  GRANT
  REFUND
}

enum ContributionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ==================== SPEND REQUESTS & VOTING ====================

model SpendRequest {
  id          String        @id @default(cuid())
  poolId      String
  requesterId String
  amount      Decimal       @db.Decimal(12, 2)
  title       String
  description String?
  category    SpendCategory
  receiptUrl  String?
  status      SpendStatus   @default(PENDING)
  isEmergency Boolean       @default(false)
  expiresAt   DateTime
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())

  pool         Pool          @relation(fields: [poolId], references: [id], onDelete: Cascade)
  requester    User          @relation(fields: [requesterId], references: [id])
  votes        Vote[]
  transactions Transaction[]

  @@index([poolId, status])
  @@index([requesterId])
  @@index([expiresAt])
}

enum SpendCategory {
  ACCOMMODATION
  TRANSPORT
  FOOD
  ACTIVITIES
  SHOPPING
  TOLL
  PETROL
  OTHER_TRIP
  RENT
  UTILITIES
  GROCERIES
  EDUCATION
  MEDICAL
  INSURANCE
  CHILDCARE
  OTHER_FAMILY
}

enum SpendStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
  EXECUTED
}

model Vote {
  id             String       @id @default(cuid())
  spendRequestId String
  voterId        String
  decision       VoteDecision
  comment        String?
  votedAt        DateTime     @default(now())

  spendRequest SpendRequest @relation(fields: [spendRequestId], references: [id], onDelete: Cascade)
  voter        User         @relation(fields: [voterId], references: [id])

  @@unique([spendRequestId, voterId])
  @@index([voterId])
}

enum VoteDecision {
  APPROVE
  REJECT
  ABSTAIN
}

// ==================== TRANSACTION LEDGER ====================

model Transaction {
  id             String               @id @default(cuid())
  poolId         String?
  userId         String
  type           TransactionType
  direction      TransactionDirection
  amount         Decimal              @db.Decimal(12, 2)
  balanceBefore  Decimal              @db.Decimal(12, 2)
  balanceAfter   Decimal              @db.Decimal(12, 2)
  description    String
  contributionId String?
  spendRequestId String?
  metadata       Json?
  createdAt      DateTime             @default(now())

  pool         Pool?         @relation(fields: [poolId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  contribution Contribution? @relation(fields: [contributionId], references: [id])
  spendRequest SpendRequest? @relation(fields: [spendRequestId], references: [id])

  @@index([poolId, createdAt])
  @@index([userId, createdAt])
  @@index([type])
}

enum TransactionType {
  CONTRIBUTION
  SPEND
  REFUND
  SETTLEMENT
  TRANSFER
  TOPUP
}

enum TransactionDirection {
  IN
  OUT
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  metadata  Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

enum NotificationType {
  CONTRIBUTION_RECEIVED
  SPEND_REQUEST_NEW
  SPEND_REQUEST_APPROVED
  SPEND_REQUEST_REJECTED
  SPEND_REQUEST_EXPIRED
  VOTE_REMINDER
  POOL_INVITE
  MEMBER_JOINED
  MEMBER_LEFT
  POOL_FROZEN
}
