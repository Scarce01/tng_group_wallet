# ===================== Node =====================
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ===================== Database (required) =====================
# Option A — Neon (free cloud Postgres, no local install, recommended for quick start):
#   1. Sign up at https://neon.tech (free tier)
#   2. Create a project → copy the connection string
#   3. Paste below. Looks like:
# DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
# Option B — local Postgres installed natively on Windows:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/tng_pool?schema=public
#
# Option C — Docker (only if Docker Desktop works on your machine):
# DATABASE_URL=postgresql://tng:tng@localhost:5432/tng_pool?schema=public
DATABASE_URL=postgresql://tng:tng@localhost:5432/tng_pool?schema=public

# ===================== Redis (OPTIONAL) =====================
# Leave blank for local dev — the app falls back to an in-process pub/sub bus
# that works fine on a single instance. Only set this when you deploy to ECS
# with 2+ replicas (ElastiCache) so WebSocket events fan out across replicas.
REDIS_URL=

# ===================== Auth =====================
JWT_ACCESS_SECRET=dev-access-secret-change-me-before-prod
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-before-prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===================== Misc =====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
WS_PATH=/ws
